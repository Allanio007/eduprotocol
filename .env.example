# ============================================================
# EduProtocol - Variaveis de Ambiente
# Copie este arquivo para .env e preencha com seus dados reais
# NUNCA commite o arquivo .env no GitHub!
# ============================================================

# Chave privada da carteira do deployer (sem o 0x)
PRIVATE_KEY=sua_chave_privada_aqui

# URL RPC da Sepolia (Infura, Alchemy, etc.)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/SEU_PROJECT_ID

# API Key do Etherscan (para verificacao de contrato)
ETHERSCAN_API_KEY=sua_api_key_etherscan

# Habilitar relatorio de gas (true/false)
REPORT_GAS=false
